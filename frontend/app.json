{
  "expo": {
    "name": "Aventaro",
    "slug": "aventaro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aventaro",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#8B5CF6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aventaro.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos for your profile and trips",
        "NSPhotoLibraryUsageDescription": "Select photos for your profile and trips",
        "NSLocationWhenInUseUsageDescription": "Share your location for safety features",
        "NSLocationAlwaysUsageDescription": "Track your location during trips for safety",
        "NSMicrophoneUsageDescription": "Record voice messages in chat"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#8B5CF6"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "RECORD_AUDIO"
      ],
      "package": "com.aventaro.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#8B5CF6"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Take photos for your profile and trips"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Share your location for safety features"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}